---
// src/pages/track.astro
export const prerender = false;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Track Your Order - Panchasara</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0"
        />
    </head>
    <body>
        <div class="track-container">
            <div class="track-header">
                <a href="/" class="logo">
                    <div class="logo-icon">P</div>
                    <span>Panchasara.</span>
                </a>
                <h1>Track Your Order</h1>
                <p>
                    Enter your order details to see the latest status updates.
                </p>
            </div>

            <div class="track-card">
                <form id="track-form" class="lookup-form">
                    <div class="input-group">
                        <label for="order_number">Order ID</label>
                        <div class="input-wrapper">
                            <span class="material-symbols-rounded"
                                >receipt_long</span
                            >
                            <input
                                type="text"
                                id="order_number"
                                placeholder="e.g. #ORD-123456"
                                required
                            />
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="identifier">Email or Phone Number</label>
                        <div class="input-wrapper">
                            <span class="material-symbols-rounded"
                                >alternate_email</span
                            >
                            <input
                                type="text"
                                id="identifier"
                                placeholder="Enter used during checkout"
                                required
                            />
                        </div>
                    </div>

                    <button type="submit" id="submit-btn" class="track-btn">
                        <span>TRACK STATUS</span>
                        <span class="material-symbols-rounded"
                            >arrow_forward</span
                        >
                    </button>
                </form>

                <div
                    id="loader"
                    class="loader-container"
                    style="display: none;"
                >
                    <div class="spinner"></div>
                    <p>Fetching your order details...</p>
                </div>

                <div
                    id="error-message"
                    class="error-box"
                    style="display: none;"
                >
                    <span class="material-symbols-rounded">error</span>
                    <p id="error-text"></p>
                </div>

                <div
                    id="order-details"
                    class="details-view"
                    style="display: none;"
                >
                    <div class="status-header">
                        <div class="order-meta">
                            <h2 id="display-order-number"></h2>
                            <p id="display-store-name"></p>
                        </div>
                        <div class="status-badge" id="display-status-badge">
                        </div>
                    </div>

                    <div class="progress-container">
                        <div class="progress-track">
                            <div class="progress-fill" id="status-progress">
                            </div>
                        </div>
                        <div class="steps">
                            <div class="step" data-status="pending">
                                <div class="step-icon">
                                    <span class="material-symbols-rounded"
                                        >timer</span>
                                </div>
                                <span>Pending</span>
                            </div>
                            <div class="step" data-status="confirmed">
                                <div class="step-icon">
                                    <span class="material-symbols-rounded"
                                        >check_circle</span>
                                </div>
                                <span>Confirmed</span>
                            </div>
                            <div class="step" data-status="preparing">
                                <div class="step-icon">
                                    <span class="material-symbols-rounded"
                                        >restaurant</span>
                                </div>
                                <span>Preparing</span>
                            </div>
                            <div class="step" data-status="ready">
                                <div class="step-icon">
                                    <span class="material-symbols-rounded"
                                        >local_mall</span>
                                </div>
                                <span>Ready</span>
                            </div>
                            <div class="step" data-status="completed">
                                <div class="step-icon">
                                    <span class="material-symbols-rounded"
                                        >verified_user</span>
                                </div>
                                <span>Delivered</span>
                            </div>
                        </div>
                    </div>

                    <div class="info-grid">
                        <div class="info-section">
                            <h3>Items</h3>
                            <div id="items-list" class="items-mini-list"></div>
                        </div>
                        <div class="info-section">
                            <h3>Delivery Details</h3>
                            <div class="detail-row">
                                <span class="label">Customer</span>
                                <span class="value" id="display-customer-name"
                                ></span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Address</span>
                                <span class="value" id="display-address"></span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Total Amount</span>
                                <span class="value price" id="display-total"
                                ></span>
                            </div>
                        </div>
                    </div>

                    <button
                        onclick="window.location.reload()"
                        class="search-again"
                    >
                        <span class="material-symbols-rounded">search</span>
                        Track Another Order
                    </button>
                </div>
            </div>
        </div>

        <style is:global>
            :root {
                --primary: #f59e0b;
                --primary-dark: #d97706;
                --bg: #fffaf0;
                --text: #1f1f1f;
                --text-muted: #64748b;
                --card-bg: #ffffff;
                --border: #e2e8f0;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                background-color: var(--bg);
                color: var(--text);
                font-family: "Inter", sans-serif;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: flex-start;
                padding: 4rem 1.5rem;
            }

            .track-container {
                width: 100%;
                max-width: 650px;
                animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .track-header {
                text-align: center;
                margin-bottom: 2.5rem;
            }

            .logo {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                margin-bottom: 1.5rem;
            }

            .logo-icon {
                width: 40px;
                height: 40px;
                background: var(--primary);
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                font-size: 1.2rem;
            }

            .logo span {
                font-weight: 800;
                font-size: 1.5rem;
                color: var(--text);
            }

            h1 {
                font-family: "Playfair Display", serif;
                font-size: 2.5rem;
                margin-bottom: 0.75rem;
            }

            .track-header p {
                color: var(--text-muted);
                font-size: 1.1rem;
            }

            .track-card {
                background: var(--card-bg);
                padding: 2.5rem;
                border-radius: 24px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
                border: 1px solid var(--border);
            }

            .lookup-form {
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
            }

            .input-group label {
                display: block;
                font-weight: 600;
                font-size: 0.9rem;
                margin-bottom: 0.5rem;
                color: var(--text-muted);
            }

            .input-wrapper {
                position: relative;
                display: flex;
                align-items: center;
            }

            .input-wrapper .material-symbols-rounded {
                position: absolute;
                left: 1rem;
                color: var(--text-muted);
                font-size: 1.25rem;
            }

            .input-wrapper input {
                width: 100%;
                padding: 1rem 1rem 1rem 3rem;
                border: 2px solid var(--border);
                border-radius: 12px;
                font-family: inherit;
                font-size: 1rem;
                transition: all 0.3s;
            }

            .input-wrapper input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
            }

            .track-btn {
                background: var(--primary);
                color: white;
                border: none;
                padding: 1.25rem;
                border-radius: 50px;
                font-weight: 800;
                font-size: 1rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                transition: all 0.3s;
                margin-top: 1rem;
            }

            .track-btn:hover {
                background: var(--primary-dark);
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(245, 158, 11, 0.3);
            }

            /* Details View */
            .details-view {
                animation: slideUp 0.5s ease-out;
            }

            @keyframes slideUp {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .status-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 2.5rem;
                padding-bottom: 1.5rem;
                border-bottom: 1px solid var(--border);
            }

            .order-meta h2 {
                font-size: 1.5rem;
                font-weight: 800;
                color: var(--text);
            }

            .order-meta p {
                color: var(--text-muted);
                font-size: 0.9rem;
            }

            .status-badge {
                padding: 0.5rem 1rem;
                border-radius: 50px;
                font-weight: 700;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            /* Progress Bar */
            .progress-container {
                margin: 3rem 0;
                position: relative;
            }

            .progress-track {
                position: absolute;
                top: 20px;
                left: 10%;
                right: 10%;
                height: 4px;
                background: var(--border);
                border-radius: 2px;
                z-index: 1;
            }

            .progress-fill {
                height: 100%;
                background: var(--primary);
                width: 0%;
                transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
            }

            .steps {
                display: flex;
                justify-content: space-between;
                position: relative;
                z-index: 2;
            }

            .step {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 8px;
                width: 60px;
                opacity: 0.4;
                transition: all 0.5s;
            }

            .step.active {
                opacity: 1;
            }

            .step.current {
                opacity: 1;
                transform: scale(1.1);
            }

            .step-icon {
                width: 40px;
                height: 40px;
                background: white;
                border: 3px solid var(--border);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--text-muted);
            }

            .step.active .step-icon {
                background: var(--primary);
                border-color: var(--primary);
                color: white;
            }

            .step span {
                font-size: 0.75rem;
                font-weight: 700;
                text-align: center;
                color: var(--text-muted);
            }

            .step.active span {
                color: var(--text);
            }

            /* Grid info */
            .info-grid {
                display: grid;
                grid-template-columns: 1.2fr 1fr;
                gap: 2.5rem;
                margin-top: 2.5rem;
            }

            .info-section h3 {
                font-size: 0.9rem;
                font-weight: 800;
                text-transform: uppercase;
                color: var(--text-muted);
                letter-spacing: 0.05em;
                margin-bottom: 1.25rem;
                padding-bottom: 0.5rem;
                border-bottom: 2px solid var(--primary);
                display: inline-block;
            }

            .items-mini-list {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            .mini-item {
                display: flex;
                justify-content: space-between;
                font-size: 0.95rem;
            }

            .mini-item .qty {
                color: var(--text-muted);
                margin-right: 8px;
            }

            .detail-row {
                margin-bottom: 1rem;
            }

            .detail-row .label {
                display: block;
                font-size: 0.8rem;
                color: var(--text-muted);
                margin-bottom: 2px;
            }

            .detail-row .value {
                font-weight: 600;
                font-size: 0.95rem;
            }

            .detail-row .price {
                font-size: 1.25rem;
                color: var(--primary-dark);
                font-weight: 800;
            }

            .search-again {
                width: 100%;
                margin-top: 3rem;
                background: none;
                border: 2px dashed var(--border);
                padding: 1rem;
                border-radius: 12px;
                cursor: pointer;
                font-weight: 700;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                transition: all 0.3s;
            }

            .search-again:hover {
                border-color: var(--primary);
                color: var(--primary);
                background: rgba(245, 158, 11, 0.05);
            }

            /* LOADER & ERROR */
            .loader-container {
                text-align: center;
                padding: 2rem 0;
            }

            .spinner {
                width: 40px;
                height: 40px;
                border: 4px solid var(--border);
                border-top-color: var(--primary);
                border-radius: 50%;
                margin: 0 auto 1.5rem;
                animation: spin 1s linear infinite;
            }

            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }

            .error-box {
                background: #fef2f2;
                border: 1px solid #fee2e2;
                color: #ef4444;
                padding: 1.5rem;
                border-radius: 12px;
                display: flex;
                align-items: center;
                gap: 12px;
                margin-top: 1.5rem;
            }

            @media (max-width: 600px) {
                .info-grid {
                    grid-template-columns: 1fr;
                }
                .track-card {
                    padding: 1.5rem;
                }
                .steps {
                    gap: 4px;
                }
                .step {
                    width: 45px;
                }
                .step span {
                    font-size: 0.65rem;
                }
            }
        </style>

        <script>
            import { supabase } from "../lib/supabase";

            const form = document.getElementById("track-form");
            const loader = document.getElementById("loader");
            const errorBox = document.getElementById("error-message");
            const errorText = document.getElementById("error-text");
            const detailsView = document.getElementById("order-details");
            const submitBtn = document.getElementById(
                "submit-btn",
            ) as HTMLButtonElement;

            // Auto-fill from URL params
            const params = new URLSearchParams(window.location.search);
            const urlOrderNum = params.get("number");
            const urlEmail = params.get("email");

            if (urlOrderNum)
                (
                    document.getElementById("order_number") as HTMLInputElement
                ).value = urlOrderNum;
            if (urlEmail)
                (
                    document.getElementById("identifier") as HTMLInputElement
                ).value = urlEmail;

            if (urlOrderNum && urlEmail) {
                setTimeout(() => form?.dispatchEvent(new Event("submit")), 100);
            }

            form?.addEventListener("submit", async (e) => {
                e.preventDefault();
                const orderNumber = (
                    document.getElementById("order_number") as HTMLInputElement
                ).value.trim();
                const identifier = (
                    document.getElementById("identifier") as HTMLInputElement
                ).value.trim();

                // Reset UI
                errorBox!.style.display = "none";
                detailsView!.style.display = "none";
                loader!.style.display = "block";
                submitBtn.disabled = true;

                try {
                    const { data, error } = await supabase.rpc(
                        "get_order_by_number",
                        {
                            p_order_number: orderNumber.replace("#", ""),
                            p_identifier: identifier,
                        },
                    );

                    if (error) throw error;
                    if (!data) {
                        showError(
                            "Order not found or details don't match. Please check and try again.",
                        );
                        return;
                    }

                    renderOrder(data);
                } catch (err: any) {
                    console.error("Tracking Error:", err);
                    showError("Something went wrong. Please try again later.");
                } finally {
                    loader!.style.display = "none";
                    submitBtn.disabled = false;
                }
            });

            function showError(msg: string) {
                errorText!.textContent = msg;
                errorBox!.style.display = "flex";
                loader!.style.display = "none";
            }

            function renderOrder(data: any) {
                const order = data.order;
                const items = data.items;
                const store = data.store;

                // Meta
                document.getElementById("display-order-number")!.textContent =
                    `#${order.order_number}`;
                document.getElementById("display-store-name")!.textContent =
                    `Ordered from ${store.name}`;

                const badge = document.getElementById("display-status-badge")!;
                badge.textContent = order.order_status;
                badge.className = `status-badge ${order.order_status}`;

                // Delivery
                document.getElementById("display-customer-name")!.textContent =
                    order.customer_name;
                document.getElementById("display-address")!.textContent =
                    order.delivery_address || "Pickup from Store";
                document.getElementById("display-total")!.textContent =
                    `₹${order.total_amount}`;

                // Items
                const list = document.getElementById("items-list")!;
                list.innerHTML = items
                    .map(
                        (i: any) => `
                    <div class="mini-item">
                        <span><span class="qty">${i.quantity}x</span> ${i.product_name}</span>
                        <span>₹${i.item_total}</span>
                    </div>
                `,
                    )
                    .join("");

                // Progress Bar
                updateProgress(order.order_status);

                // Show view
                form!.style.display = "none";
                detailsView!.style.display = "block";
            }

            function updateProgress(status: string) {
                const statuses = [
                    "pending",
                    "confirmed",
                    "preparing",
                    "ready",
                    "completed",
                ];
                const currentIndex = statuses.indexOf(status.toLowerCase());
                const steps = document.querySelectorAll(".step");
                const progressFill =
                    document.getElementById("status-progress")!;

                steps.forEach((step, idx) => {
                    if (idx <= currentIndex) step.classList.add("active");
                    else step.classList.remove("active");

                    if (idx === currentIndex) step.classList.add("current");
                    else step.classList.remove("current");
                });

                const percentage = (currentIndex / (statuses.length - 1)) * 100;
                progressFill.style.width = `${percentage}%`;
            }
        </script>
    </body>
</html>
