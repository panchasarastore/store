---
// src/pages/orders/success.astro
import { supabase } from "../../lib/supabase";

const url = new URL(Astro.request.url);
const slug = url.searchParams.get("slug");

let store = null;
if (slug) {
    const { data } = await supabase
        .from("stores")
        .select("*")
        .eq("store_url_slug", slug)
        .single();
    store = data;
}

const theme = store?.theme || {};
const colors = theme.colors || theme;
const primaryColor = "#FF9D42"; // Panchasara Orange for Panchasara elements
const storeAccent = colors.primary || "#5b3a1e";
const bgColor = "#FFFAF7";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Order Successful - {store?.store_name || "Store"}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0"
        />
    </head>
    <body>
        <div class="success-container">
            <!-- Receipt Header / Panchasara Branding -->
            <div class="panchasara-brand">
                Panchasara<span>·</span>🍯
            </div>

            <!-- Receipt Roller -->
            <div class="receipt-roller">
                <div class="roller-holes">
                    {
                        Array(15)
                            .fill(0)
                            .map(() => <div class="hole" />)
                    }
                </div>
            </div>

            <div class="success-card">
                <!-- Status Badge -->
                <div class="status-badge">Order Confirmed</div>

                <div class="icon-circle">
                    <span class="material-symbols-rounded">check_circle</span>
                </div>

                <h1>Order Placed!</h1>
                <p>
                    Thank you for your order. We've received your request and
                    will start preparing it shortly.
                </p>

                <div class="order-info">
                    <div class="info-row">
                        <span class="material-symbols-rounded"
                            >receipt_long</span
                        >
                        <span>An email confirmation will be sent soon.</span>
                    </div>
                </div>

                <div class="action-buttons">
                    <a href="/track" class="track-btn-success">
                        TRACK YOUR ORDER
                        <span class="material-symbols-rounded">location_on</span
                        >
                    </a>

                    <a href={slug ? `/${slug}` : "/"} class="back-btn">
                        CONTINUE SHOPPING
                        <span class="material-symbols-rounded"
                            >arrow_forward</span
                        >
                    </a>
                </div>

                <!-- Receipt Tear Line -->
                <div class="tear-line">
                    {
                        Array(20)
                            .fill(0)
                            .map(() => <span />)
                    }
                </div>
            </div>

            <div class="footer-note">
                Sent via <b>Panchasara</b> for <b
                    >{store?.store_name || "the store"}</b
                >
            </div>
        </div>

        <style define:vars={{ primaryColor, storeAccent, bgColor }}>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background-color: var(--bgColor);
                color: #0d0d0d;
                font-family: "Plus Jakarta Sans", sans-serif;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                padding: 40px 16px;
            }

            .success-container {
                width: 100%;
                max-width: 480px;
                animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            }

            @keyframes slideUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .panchasara-brand {
                text-align: center;
                font-family: "Lexend", sans-serif;
                font-size: 13px;
                font-weight: 800;
                letter-spacing: 5px;
                text-transform: uppercase;
                color: #4a4540;
                margin-bottom: 24px;
            }

            .panchasara-brand span {
                color: var(--primaryColor);
            }

            .receipt-roller {
                background: #1e1c1a;
                border-radius: 12px 12px 0 0;
                height: 44px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: inset 0 -4px 8px rgba(0, 0, 0, 0.4);
                position: relative;
                z-index: 2;
            }

            .roller-holes {
                display: flex;
                gap: 12px;
            }

            .hole {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: #0d0c0b;
                box-shadow: inset 0 1px 3px rgba(0, 0, 0, 1);
            }

            .success-card {
                background: white;
                padding: 40px 32px 60px;
                text-align: center;
                border-left: 1px solid #e0dbd2;
                border-right: 1px solid #e0dbd2;
                position: relative;
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.04);
            }

            .status-badge {
                display: inline-flex;
                align-items: center;
                background: #fff4ed;
                color: var(--primaryColor);
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                padding: 6px 14px;
                border-radius: 100px;
                margin-bottom: 24px;
                box-shadow: 0 2px 8px rgba(255, 157, 66, 0.1);
            }

            .icon-circle {
                width: 72px;
                height: 72px;
                background: #f0fdf4;
                color: #22c55e;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
            }

            .icon-circle .material-symbols-rounded {
                font-size: 36px;
                font-variation-settings: "FILL" 1;
            }

            h1 {
                font-family: "Lexend", sans-serif;
                font-size: 28px;
                font-weight: 800;
                color: #0d0d0d;
                margin-bottom: 12px;
                letter-spacing: -0.02em;
            }

            p {
                font-size: 15px;
                line-height: 1.6;
                color: #6b7280;
                margin-bottom: 30px;
            }

            .order-info {
                background: #fdfcf8;
                padding: 18px;
                border-radius: 12px;
                border: 1.5px dashed #e0dbd2;
                margin-bottom: 32px;
            }

            .info-row {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                color: #4b5563;
                font-weight: 600;
                font-size: 13px;
            }

            .info-row .material-symbols-rounded {
                font-size: 20px;
                color: var(--primaryColor);
            }

            .action-buttons {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            .track-btn-success {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                padding: 16px;
                background: var(--primaryColor);
                color: white;
                text-decoration: none;
                border-radius: 12px;
                font-family: "Lexend", sans-serif;
                font-weight: 700;
                font-size: 14px;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                transition: all 0.3s ease;
                box-shadow: 0 4px 15px rgba(255, 157, 66, 0.25);
            }

            .track-btn-success:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(255, 157, 66, 0.35);
            }

            .back-btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                padding: 16px;
                background: var(--storeAccent);
                color: white;
                text-decoration: none;
                border-radius: 12px;
                font-family: "Lexend", sans-serif;
                font-weight: 700;
                font-size: 14px;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                transition: all 0.3s ease;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            }

            .back-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            .tear-line {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                display: flex;
                overflow: hidden;
                transform: translateY(50%);
            }

            .tear-line span {
                min-width: 24px;
                height: 12px;
                background: var(--bgColor);
                border-radius: 50%;
                margin: 0 2px;
            }

            .footer-note {
                text-align: center;
                margin-top: 40px;
                font-size: 12px;
                color: #9a948d;
                line-height: 1.8;
            }

            .footer-note b {
                color: #4a4540;
            }
        </style>
    </body>
</html>
