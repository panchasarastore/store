---
// src/components/setup/SetupContact.astro
interface Props {
    initialStore: {
        address: string;
        email: string;
        whatsapp_number: string;
        instagram: string;
        facebook: string;
        show_email: boolean;
        show_whatsapp: boolean;
        show_instagram: boolean;
        show_facebook: boolean;
    };
    errors?: Record<string, string>;
}

const { initialStore, errors = {} } = Astro.props;
---

<section class="space-y-5">
    <div
        class="flex items-center gap-2 text-slate-800 border-b border-slate-100 pb-2"
    >
        <span class="material-symbols-rounded text-primary">contacts</span>
        <h2 class="font-display font-bold text-lg">Contact</h2>
    </div>

    <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
        <div class="flex justify-between items-center mb-2">
            <span class="text-xs font-bold text-slate-500 uppercase"
                >Store Location</span
            >
        </div>
        <input
            type="text"
            id="store_address_input"
            name="store_address"
            placeholder="City, Region (e.g. Kochi, Kerala)"
            value={initialStore.address}
            required
            class={`w-full px-3 py-2 rounded-lg border bg-white focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all ${errors.store_address ? "border-red-500 ring-1 ring-red-100" : "border-slate-200"}`}
        />
        {
            errors.store_address && (
                <p class="text-xs text-red-500 mt-1 font-bold italic">
                    {errors.store_address}
                </p>
            )
        }
        <p class="text-[10px] text-slate-500 mt-2 ml-1 leading-tight">
            📍 This address is used to show "Store Pickup" options and calculate
            delivery during checkout.
        </p>
    </div>

    <div class="space-y-4">
        <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
            <div class="flex justify-between items-center mb-2">
                <span class="text-xs font-bold text-slate-500 uppercase"
                    >Email</span
                >
                <label class="relative inline-flex items-center cursor-pointer">
                    <input
                        type="checkbox"
                        name="show_email"
                        checked={initialStore.show_email}
                        class="sr-only peer"
                    />
                    <div
                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"
                    >
                    </div>
                </label>
            </div>
            <input
                type="email"
                id="contact_email_input"
                name="contact_email"
                placeholder="Email"
                value={initialStore.email}
                class={`w-full px-3 py-2 rounded-lg border bg-white focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all ${errors.contact_email ? "border-red-500 ring-1 ring-red-100" : "border-slate-200"}`}
            />
            {
                errors.contact_email && (
                    <p class="text-xs text-red-500 mt-1 font-bold italic">
                        {errors.contact_email}
                    </p>
                )
            }
        </div>

        <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
            <div class="flex justify-between items-center mb-2">
                <span class="text-xs font-bold text-slate-500 uppercase"
                    >WhatsApp</span
                >
                <label class="relative inline-flex items-center cursor-pointer">
                    <input
                        type="checkbox"
                        name="show_whatsapp"
                        checked={initialStore.show_whatsapp}
                        class="sr-only peer"
                    />
                    <div
                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"
                    >
                    </div>
                </label>
            </div>
            <input
                type="tel"
                id="whatsapp_number_input"
                name="whatsapp_number"
                placeholder="Number (e.g. +91...)"
                value={initialStore.whatsapp_number}
                class={`w-full px-3 py-2 rounded-lg border bg-white focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all ${errors.whatsapp_number ? "border-red-500 ring-1 ring-red-100" : "border-slate-200"}`}
            />
            {
                errors.whatsapp_number && (
                    <p class="text-xs text-red-500 mt-1 font-bold italic">
                        {errors.whatsapp_number}
                    </p>
                )
            }
            <p
                class="text-[10px] text-slate-400 mt-1.5 ml-1 flex items-center gap-1"
                id="whatsapp_hint"
            >
                <span class="material-symbols-rounded text-[12px]">info</span>
                Include country code for the WhatsApp link to work.
            </p>
        </div>

        <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
            <div class="flex justify-between items-center mb-2">
                <span class="text-xs font-bold text-slate-500 uppercase"
                    >Instagram</span
                >
                <label class="relative inline-flex items-center cursor-pointer">
                    <input
                        type="checkbox"
                        name="show_instagram"
                        checked={initialStore.show_instagram}
                        class="sr-only peer"
                    />
                    <div
                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"
                    >
                    </div>
                </label>
            </div>
            <input
                type="url"
                id="instagram_url_input"
                name="instagram_url"
                placeholder="https://instagram.com/myhandle"
                pattern="^https?:\/\/(www\.)?instagram\.com\/[a-zA-Z0-9._]+\/?$"
                title="Please enter a valid Instagram profile URL (e.g., https://instagram.com/shopname)"
                value={initialStore.instagram}
                class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-white focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all"
            />
            <p
                class="text-[10px] text-slate-400 mt-1.5 ml-1 flex items-center gap-1"
                id="instagram_hint"
            >
                <span class="material-symbols-rounded text-[12px]">info</span>
                Copy your full profile link from the browser (e.g. instagram.com/myhandle)
            </p>
        </div>

        <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
            <div class="flex justify-between items-center mb-2">
                <span class="text-xs font-bold text-slate-500 uppercase"
                    >Facebook</span
                >
                <label class="relative inline-flex items-center cursor-pointer">
                    <input
                        type="checkbox"
                        name="show_facebook"
                        checked={initialStore.show_facebook}
                        class="sr-only peer"
                    />
                    <div
                        class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"
                    >
                    </div>
                </label>
            </div>
            <input
                type="url"
                id="facebook_url_input"
                name="facebook_url"
                placeholder="https://facebook.com/myshop"
                pattern="^https?:\/\/(www\.)?facebook\.com\/[a-zA-Z0-9.]+\/?$"
                title="Please enter a valid Facebook profile or page URL (e.g., https://facebook.com/shopname)"
                value={initialStore.facebook}
                class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-white focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all"
            />
            <p
                class="text-[10px] text-slate-400 mt-1.5 ml-1 flex items-center gap-1"
                id="facebook_hint"
            >
                <span class="material-symbols-rounded text-[12px]">info</span>
                Enter your full Facebook Page or profile address.
            </p>
        </div>
    </div>
</section>
