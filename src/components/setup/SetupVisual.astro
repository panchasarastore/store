---
// src/components/setup/SetupVisual.astro
interface Props {
    previewTheme: any;
    previewFonts: any;
    layout_preset?: string;
    errors?: Record<string, string>;
}

const { previewTheme, previewFonts, layout_preset, errors = {} } = Astro.props;
---

<section class="space-y-6">
    <div
        class="flex items-center gap-2 text-slate-800 border-b border-slate-100 pb-2"
    >
        <span class="material-symbols-rounded text-primary">palette</span>
        <h2 class="font-display font-bold text-lg">Visual Identity</h2>
    </div>

    <div>
        <label
            class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-3"
            >1. Choose a Vibe</label
        >
        <div class="grid grid-cols-3 gap-3">
            <label class="cursor-pointer relative group">
                <input
                    type="radio"
                    name="layout_preset"
                    value="natural"
                    checked={previewFonts.body === "natural" ||
                        Astro.props.layout_preset === "natural"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center h-full flex flex-col items-center justify-center gap-2"
                >
                    <div class="w-6 h-6 rounded-full bg-[#5D4037]"></div>
                    <span class="text-[10px] uppercase font-bold text-slate-600"
                        >Natural</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative group">
                <input
                    type="radio"
                    name="layout_preset"
                    value="gallery"
                    checked={previewFonts.body === "gallery" ||
                        Astro.props.layout_preset === "gallery"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center h-full flex flex-col items-center justify-center gap-2"
                >
                    <div
                        class="w-6 h-6 rounded-full bg-black border border-slate-200"
                    >
                    </div>
                    <span class="text-[10px] uppercase font-bold text-slate-600"
                        >Gallery</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative group">
                <input
                    type="radio"
                    name="layout_preset"
                    value="pop"
                    checked={previewFonts.body === "pop" ||
                        Astro.props.layout_preset === "pop"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center h-full flex flex-col items-center justify-center gap-2"
                >
                    <div class="w-6 h-6 rounded-full bg-[#E91E63]"></div>
                    <span class="text-[10px] uppercase font-bold text-slate-600"
                        >Pop</span
                    >
                </div>
            </label>
        </div>
    </div>

    <div class="pt-2">
        <button
            type="button"
            id="toggle-advanced"
            class="flex items-center gap-2 text-xs font-bold text-primary hover:text-primary-hover transition-colors mb-4"
        >
            <span class="material-symbols-rounded text-lg">tune</span>
            Customize Colors
        </button>

        <div
            id="advanced-options"
            class="advanced-colors grid grid-cols-2 gap-4"
        >
            <div>
                <label
                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1"
                    >Brand (Logo)</label
                >
                <div
                    class="flex items-center w-full p-2 rounded-xl border border-slate-200 bg-white"
                >
                    <input
                        type="color"
                        name="color_primary"
                        value={previewTheme.primary || "#5b3a1e"}
                        class="w-8 h-8 rounded-lg border-none p-0 cursor-pointer"
                    />
                </div>
            </div>
            <div>
                <label
                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1"
                    >Button Accent</label
                >
                <div
                    class="flex items-center w-full p-2 rounded-xl border border-slate-200 bg-white"
                >
                    <input
                        type="color"
                        name="color_secondary"
                        value={previewTheme.secondary || "#c46a2b"}
                        class="w-8 h-8 rounded-lg border-none p-0 cursor-pointer"
                    />
                </div>
            </div>
            <div>
                <label
                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1"
                    >Page Background</label
                >
                <div
                    class="flex items-center w-full p-2 rounded-xl border border-slate-200 bg-white"
                >
                    <input
                        type="color"
                        name="color_background"
                        value={previewTheme.background || "#fffaf0"}
                        class="w-8 h-8 rounded-lg border-none p-0 cursor-pointer"
                    />
                </div>
            </div>
            <div>
                <label
                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1"
                    >Text / Ink</label
                >
                <div
                    class="flex items-center w-full p-2 rounded-xl border border-slate-200 bg-white"
                >
                    <input
                        type="color"
                        name="color_text"
                        value={previewTheme.text || "#1f1f1f"}
                        class="w-8 h-8 rounded-lg border-none p-0 cursor-pointer"
                    />
                </div>
            </div>
            <div class="col-span-2">
                <label
                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1"
                    >Header/Footer Bg</label
                >
                <div
                    class="flex items-center w-full p-2 rounded-xl border border-slate-200 bg-white"
                >
                    <input
                        type="color"
                        name="color_header"
                        value={previewTheme.header || "#fffaf0"}
                        class="w-8 h-8 rounded-lg border-none p-0 cursor-pointer"
                    />
                    <span class="ml-2 text-xs text-slate-400"
                        >Usually matches page bg</span
                    >
                </div>
            </div>
        </div>
    </div>

    <div>
        <label
            class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-3"
            >2. Typography</label
        >
        <div class="grid grid-cols-3 gap-3">
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="softloom"
                    checked={previewFonts.heading === "softloom"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 italic"
                        style="font-family: 'Cormorant Garamond', serif;"
                        >Aa</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Softloom</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="hearth"
                    checked={previewFonts.heading === "hearth"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 font-bold"
                        style="font-family: 'Playfair Display', serif;">Aa</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Hearth</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="creator"
                    checked={previewFonts.heading === "creator"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 font-bold"
                        style="font-family: 'Sora', sans-serif;">AA</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Creator</span
                    >
                </div>
            </label>
        </div>

        <div class="grid grid-cols-3 gap-3 mt-3">
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="heritage"
                    checked={previewFonts.heading === "heritage"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 font-bold"
                        style="font-family: 'Lora', serif;">Aa</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Heritage</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="bloom"
                    checked={previewFonts.heading === "bloom"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 font-semibold"
                        style="font-family: 'Fredoka', sans-serif;">Aa</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Bloom</span
                    >
                </div>
            </label>
            <label class="cursor-pointer relative">
                <input
                    type="radio"
                    name="font_preset"
                    value="loom"
                    checked={previewFonts.heading === "loom"}
                    class="peer sr-only"
                />
                <div
                    class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 peer-checked:border-primary peer-checked:bg-orange-50 transition-all text-center"
                >
                    <span
                        class="block text-2xl mb-1 uppercase font-bold"
                        style="font-family: 'Abril Fatface', serif;">Aa</span
                    >
                    <span class="text-[10px] uppercase font-bold text-slate-500"
                        >Loom</span
                    >
                </div>
            </label>
        </div>
    </div>
</section>
