---
// src/components/setup/SetupBasics.astro
interface Props {
    initialStore: {
        name: string;
        slug: string;
    };
    errors?: Record<string, string>;
}

const { initialStore, errors = {} } = Astro.props;
---

<section class="space-y-5">
    <div
        class="flex items-center gap-2 text-slate-800 border-b border-slate-100 pb-2"
    >
        <span class="material-symbols-rounded text-primary">storefront</span>
        <h2 class="font-display font-bold text-lg">Store Basics</h2>
    </div>
    <div class="space-y-4">
        <div>
            <label
                class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5"
                >Store Name</label
            >
            <input
                type="text"
                name="store_name"
                placeholder="The Sourdough Studio"
                value={initialStore.name}
                required
                class={`w-full px-4 py-3 rounded-xl border bg-slate-50 focus:bg-white focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-medium ${errors.store_name ? "border-red-500 ring-1 ring-red-100" : "border-slate-200"}`}
            />
            {
                errors.store_name && (
                    <p class="text-xs text-red-500 mt-1 font-bold italic">
                        {errors.store_name}
                    </p>
                )
            }
        </div>
        <div>
            <label
                class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5"
                >Store URL</label
            >
            <div
                class={`flex items-center w-full px-4 py-3 rounded-xl border bg-slate-50 focus-within:bg-white focus-within:border-primary focus-within:ring-1 focus-within:ring-primary transition-all ${errors.store_url_slug ? "border-red-500 ring-1 ring-red-100" : "border-slate-200"}`}
            >
                <span class="text-slate-400 text-sm mr-1">panchasara.com/</span>
                <input
                    type="text"
                    name="store_url_slug"
                    placeholder="sourdough-studio"
                    value={initialStore.slug}
                    required
                    class="flex-1 bg-transparent border-none p-0 focus:ring-0 text-slate-900 placeholder:text-slate-400 font-medium"
                />
            </div>
            {
                errors.store_url_slug && (
                    <p class="text-xs text-red-500 mt-1 font-bold italic">
                        {errors.store_url_slug}
                    </p>
                )
            }
        </div>
    </div>
</section>
