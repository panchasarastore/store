---
const { safeStore } = Astro.props;
---

<section class="store-hero" id="about">
    <h2 class="store-tagline store-template-tagline">{safeStore.tagline}</h2>
    <div class="store-about-preview">
        <p class="store-template-about">{safeStore.about}</p>
    </div>
</section>

<style is:inline>
    .store-hero {
        padding: 5rem 1rem 3rem;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .store-tagline {
        font-family: var(--font-display);
        font-size: 3rem;
        line-height: 1.1;
        margin-bottom: 2rem;
        color: var(--theme-ink);
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }
    .store-about-preview p {
        font-size: 1.15rem;
        line-height: 1.8;
        opacity: 0;
        color: var(--theme-ink);
        margin-bottom: 2rem;
        white-space: pre-wrap;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .store-hero {
            padding: 2rem 1rem 1rem;
        }
        .store-tagline {
            font-size: 2rem;
        }
    }
</style>
