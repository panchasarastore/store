---
import { supabase } from "../../lib/supabase";
import StoreNavbar from "./StoreNavbar.astro";
import StoreHero from "./StoreHero.astro";
import CategoryBar from "./CategoryBar.astro";
import ProductGrid from "./ProductGrid.astro";
import ProductModal from "./ProductModal.astro";
import CartDrawer from "./CartDrawer.astro";
import CheckoutWizard from "./CheckoutWizard.astro";
import PaymentProcessor from "./PaymentProcessor.astro";
import StoreFooter from "./StoreFooter.astro";

const {
  store = {},
  theme = {},
  products = [],
  isPreview = false,
  layout = "natural",
  font = "classic",
} = Astro.props;

// 1. Safe Defaults
const safeStore = {
  id: store.id,
  name: store.name || "Your Store Name",
  tagline: store.tagline || "A short soulful tagline",
  about:
    store.about ||
    "Tell customers about your craft, your journey, and what makes you special.",
  logo: store.logo || null,
  address: store.address || null,
  email: store.contact_email,
  whatsapp: store.whatsapp_number,
  instagram: store.instagram_url,
  facebook: store.facebook_url,
};

// 2. Color Mapping
const hexToRgb = (hex: string) => {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r}, ${g}, ${b}`;
};

const primaryHex = theme.primary || "#5b3a1e";
const secondaryHex = theme.secondary || "#c46a2b";

const colorStyles = {
  "--theme-brand": primaryHex,
  "--theme-accent": secondaryHex,
  "--theme-accent-rgb": hexToRgb(secondaryHex),
  "--theme-page": theme.background || "#fffaf0",
  "--theme-ink": theme.text || "#1f1f1f",
  "--theme-header-bg": theme.header || theme.background || "#fffaf0",
};

// 3. Dynamic Categories
const productCats = (products as any[])
  .map((p: any) => p.category)
  .filter(
    (cat: string, index: number, self: string[]) =>
      cat && self.indexOf(cat) === index,
  )
  .sort();

const categories = ["All", ...productCats];

// 4. Products
const displayProducts = products;
---

<div
  class="store-template-wrapper"
  data-preview={isPreview}
  style={colorStyles}
  data-font-preset={font}
  data-layout={layout}
  data-products={JSON.stringify(displayProducts)}
  data-store-id={safeStore.id}
  data-is-preview={isPreview}
>
  <StoreNavbar safeStore={safeStore} />

  <StoreHero safeStore={safeStore} />

  <CategoryBar categories={categories} />

  <ProductGrid displayProducts={displayProducts} />

  <StoreFooter safeStore={safeStore} />

  <ProductModal />

  <CartDrawer />

  <CheckoutWizard safeStore={safeStore} />

  <PaymentProcessor />

  <!-- TOAST NOTIFICATION SYSTEM -->
  <div id="toast-container" class="toast-container"></div>

  <script is:inline>
    // Global Toast Function
    window.showToast = (message, type = "error") => {
      const container = document.getElementById("toast-container");
      if (!container) return;

      const toast = document.createElement("div");
      toast.className = `toast-message ${type}`;
      toast.innerHTML = `
        <span class="material-symbols-rounded">${type === "error" ? "error" : "check_circle"}</span>
        <span class="toast-text">${message}</span>
      `;

      container.appendChild(toast);

      // Trigger animation
      setTimeout(() => toast.classList.add("show"), 10);

      // Auto-remove
      setTimeout(() => {
        toast.classList.remove("show");
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    };
  </script>

  <script>
    import { supabase } from "../../lib/supabase";
    (window as any).supabase = supabase;
  </script>

  <style is:inline>
    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@400;600;700&family=Sora:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;700&family=Fredoka:wght@400;600&family=Quicksand:wght@400;600;700&family=Abril+Fatface&family=Mulish:wght@400;600;700&display=swap");

    /* =========================================
   CORE VARIABLES & RESET
========================================= */
    .store-template-wrapper {
      --spacing-container: 92%;
      --max-width: 1200px;

      --theme-brand: #5b3a1e;
      --theme-accent: #c46a2b;
      --theme-page: #fffaf0;
      --theme-ink: #1f1f1f;

      --font-display: "Playfair Display", serif;
      --font-heading: "Playfair Display", serif;
      --font-body: "Inter", sans-serif;

      --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      --shadow-premium:
        0 10px 30px -5px rgba(0, 0, 0, 0.05),
        0 5px 15px -8px rgba(0, 0, 0, 0.05);
      --shadow-hover: 0 20px 40px -10px rgba(0, 0, 0, 0.1);

      background-color: var(--theme-page);
      background-image:
        radial-gradient(
          circle at top right,
          rgba(255, 255, 255, 0.5),
          transparent
        ),
        radial-gradient(circle at bottom left, rgba(0, 0, 0, 0.02), transparent);
      color: var(--theme-ink);
      font-family: var(--font-body);
      width: 100%;
      min-height: 100%;
      position: relative;
      overflow-x: hidden;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: background-color 0.5s ease;
    }

    /* UTILITIES */
    .glass-effect {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(12px) saturate(180%);
      -webkit-backdrop-filter: blur(12px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .premium-shadow {
      box-shadow: var(--shadow-premium);
      transition: var(--transition-smooth);
    }

    .premium-shadow:hover {
      box-shadow: var(--shadow-hover);
    }

    /* FONT PRESETS */
    .store-template-wrapper[data-font-preset="softloom"] {
      --font-display: "Cormorant+Garamond", serif;
      --font-heading: "Cormorant+Garamond", serif;
      --font-body: "DM+Sans", sans-serif;
    }
    .store-template-wrapper[data-font-preset="softloom"] .store-template-name {
      font-family: "Cormorant Garamond", serif;
      font-style: italic;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .store-template-wrapper[data-font-preset="softloom"] .store-tagline {
      font-family: "Cormorant Garamond", serif;
      font-style: italic;
    }

    .store-template-wrapper[data-font-preset="hearth"] {
      --font-display: "Playfair+Display", serif;
      --font-heading: "Playfair+Display", serif;
      --font-body: "Nunito", sans-serif;
    }
    .store-template-wrapper[data-font-preset="hearth"] .store-template-name {
      font-family: "Playfair Display", serif;
      font-weight: 700;
    }
    .store-template-wrapper[data-font-preset="hearth"] .store-tagline {
      font-family: "Playfair Display", serif;
      font-style: italic;
    }

    .store-template-wrapper[data-font-preset="creator"] {
      --font-display: "Sora", sans-serif;
      --font-heading: "Sora", sans-serif;
      --font-body: "Sora", sans-serif;
    }
    .store-template-wrapper[data-font-preset="creator"] .store-template-name {
      font-family: "Sora", sans-serif;
      font-weight: 700;
    }

    .store-template-wrapper[data-font-preset="heritage"] {
      --font-display: "Lora", serif;
      --font-heading: "Lora", serif;
      --font-body: "Inter", sans-serif;
    }
    .store-template-wrapper[data-font-preset="heritage"] .store-template-name {
      font-family: "Lora", serif;
      font-weight: 700;
    }
    .store-template-wrapper[data-font-preset="heritage"] .store-tagline {
      font-family: "Lora", serif;
      font-style: italic;
    }

    .store-template-wrapper[data-font-preset="bloom"] {
      --font-display: "Fredoka", sans-serif;
      --font-heading: "Fredoka", sans-serif;
      --font-body: "Quicksand", sans-serif;
    }
    .store-template-wrapper[data-font-preset="bloom"] .store-template-name {
      font-family: "Fredoka", sans-serif;
      font-weight: 600;
    }

    .store-template-wrapper[data-font-preset="loom"] {
      --font-display: "Abril+Fatface", serif;
      --font-heading: "Abril+Fatface", serif;
      --font-body: "Mulish", sans-serif;
    }
    .store-template-wrapper[data-font-preset="loom"] .store-template-name {
      font-family: "Abril Fatface", serif;
      font-weight: 400;
    }

    /* LAYOUT PRESETS */
    .store-template-wrapper[data-layout="gallery"] {
      --spacing-container: 100%;
      --max-width: 1400px;
    }
    .store-template-wrapper[data-layout="gallery"] .store-navbar {
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .store-template-wrapper[data-layout="pop"] {
      --spacing-container: 85%;
      --max-width: 1100px;
    }
    .store-template-wrapper[data-layout="pop"] .product-card {
      border-radius: 4px;
      transform: rotate(-0.5deg);
    }
    .store-template-wrapper[data-layout="pop"] .product-card:nth-child(even) {
      transform: rotate(0.5deg);
    }

    /* Global Scroll & Helper Styles */
    html {
      scroll-behavior: smooth;
    }
    section[id] {
      scroll-margin-top: 100px;
    }

    /* MINI STEPPER (Used in Cart) */
    .mini-stepper {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(0, 0, 0, 0.03);
      padding: 4px 8px;
      border-radius: 50px;
    }
    .mini-step-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      color: var(--theme-ink);
      opacity: 0.6;
      transition: opacity 0.2s;
    }
    .mini-step-btn:hover {
      opacity: 1;
    }
    .mini-step-qty {
      font-weight: 700;
      font-size: 0.9rem;
      min-width: 15px;
      text-align: center;
    }

    /* ERROR STATES */
    .input-error {
      border-color: #ef4444 !important;
      background-color: #fef2f2 !important;
      animation: shake 0.4s ease-in-out;
    }
    @keyframes shake {
      0%,
      100% {
        transform: translateX(0);
      }
      25% {
        transform: translateX(-5px);
      }
      75% {
        transform: translateX(5px);
      }
    }

    .select-wrapper {
      position: relative;
      width: 100%;
    }
    .select-wrapper::after {
      content: "\e5cf";
      font-family: "Material Symbols Rounded";
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      opacity: 0.5;
    }

    .info-box {
      font-size: 0.9rem;
      line-height: 1.5;
    }

    /* CART & BUTTON ANIMATIONS */
    @keyframes cart-bump {
      0% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.3);
      }
      100% {
        transform: scale(1);
      }
    }
    .cart-bump {
      animation: cart-bump 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @keyframes button-pop {
      0% {
        transform: scale(0.95);
        opacity: 0.8;
      }
      50% {
        transform: scale(1.05);
        opacity: 1;
      }
      100% {
        transform: scale(1);
      }
    }
    .button-click-pop {
      animation: button-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    /* STEPPER REFINEMENT */
    .stepper-controls {
      display: flex;
      align-items: center;
      gap: 12px;
      background: white;
      padding: 2px;
      border-radius: 12px;
      border: 1.5px solid rgba(0, 0, 0, 0.05);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .step-btn {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: rgba(0, 0, 0, 0.03);
      color: var(--theme-brand);
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .step-btn:hover {
      background: var(--theme-brand);
      color: white;
    }

    .qty-display {
      font-weight: 800;
      min-width: 20px;
      text-align: center;
      font-size: 0.95rem;
      color: var(--theme-brand);
    }

    /* TOAST STYLES */
    .toast-container {
      position: fixed;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      pointer-events: none;
    }
    .toast-message {
      background: white;
      color: #1f1f1f;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-weight: 600;
      font-size: 0.9rem;
      opacity: 0;
      transform: translateY(-20px);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border-left: 4px solid var(--theme-accent);
      min-width: 300px;
    }
    .toast-message.show {
      opacity: 1;
      transform: translateY(0);
    }
    .toast-message.error {
      border-left-color: #ef4444;
    }
    .toast-message .material-symbols-rounded {
      font-size: 1.25rem;
    }
    .toast-message.error .material-symbols-rounded {
      color: #ef4444;
    }
    .toast-text {
      flex: 1;
    }

    @media (max-width: 768px) {
      .toast-container {
        top: auto;
        bottom: 2rem;
        width: 90%;
      }
      .toast-message {
        min-width: 0;
        width: 100%;
      }
    }
    /* CART WARNINGS */
    .cart-item.has-error {
      background: rgba(239, 68, 68, 0.03);
      border-radius: 12px;
      padding: 0.5rem;
      margin: -0.5rem;
    }
    .stock-warning {
      color: #ef4444;
      font-size: 0.75rem;
      font-weight: 700;
      margin-top: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .disabled-opacity {
      opacity: 0.5;
      cursor: not-allowed !important;
    }
  </style>

  <script>
    import { cartItems, updateQuantity, initCart } from "../../lib/cartStore";
    import { setupStoreUI } from "../../lib/dom/store-ui";
    import {
      syncUI,
      renderCart,
      attachStepperLogic,
    } from "../../lib/dom/cart-sync";
    import { setupModalLogic } from "../../lib/dom/modal";
    import {
      setupCheckoutLogic,
      renderCheckoutSummary,
    } from "../../lib/dom/checkout";

    // ==========================================
    // 1. DATA & STATE
    // ==========================================
    const wrapper = document.querySelector(
      ".store-template-wrapper",
    ) as HTMLElement;
    const productsData = wrapper?.dataset.products
      ? JSON.parse(wrapper.dataset.products)
      : [];
    const isPreview = wrapper?.dataset.isPreview === "true";
    const storeId = wrapper?.dataset.storeId;

    // ==========================================
    // 2. INITIALIZE ALL MODULES
    // ==========================================
    if (storeId && !isPreview) {
      initCart(storeId);
    }

    setupStoreUI();
    const toggleCart = (window as any).toggleCart;

    // Make updateQuantity available globally for inline onclick handlers in cart-sync.ts
    (window as any).updateCartItem = (id: string, qty: number) => {
      const items = cartItems.get();
      const item = items.find((i: any) => i.id === id);
      const success = updateQuantity(id, qty);
      if (!success && qty > (item?.quantity || 0)) {
        (window as any).showToast?.(
          "Limit reached: Only " + item?.stock_quantity + " available",
        );
      }
    };

    setupModalLogic(productsData, toggleCart);

    // PREVIEW PROTECTION: Disable checkout listeners if in preview mode
    if (isPreview) {
      console.log("Store in Preview Mode: Checkout functionality disabled.");
      const checkoutBtn = document.querySelector(".checkout-btn");
      if (checkoutBtn) {
        (checkoutBtn as HTMLButtonElement).disabled = true;
        checkoutBtn.innerHTML = "CHECKOUT (DISABLED IN PREVIEW)";
        checkoutBtn.classList.add("opacity-50", "cursor-not-allowed");
      }

      // Override toggleCart to prevent opening in preview if desired,
      // or just leave it to show the empty bag.
    } else {
      setupCheckoutLogic(renderCheckoutSummary, toggleCart);
    }

    // Initialize Product Cards helper
    function attachToCard(card: HTMLElement) {
      const pid = card.dataset.id;
      const stepperWrapper = card.querySelector(".add-action-wrapper");
      if (stepperWrapper && pid)
        attachStepperLogic(stepperWrapper, pid, productsData, toggleCart);

      // Add click handler for modal
      card.addEventListener("click", () => {
        if ((window as any).openProductModal) {
          const product = productsData.find((p: any) => p.id === pid);
          if (product) (window as any).openProductModal(product);
        }
      });
    }

    document
      .querySelectorAll(".product-card")
      .forEach((card) => attachToCard(card as HTMLElement));

    // ==========================================
    // 3. LOAD MORE LOGIC
    // ==========================================
    let currentPage = 1;
    const PAGE_SIZE = 24;
    const loadMoreBtn = document.getElementById("load-more-btn");
    const productsGrid = document.getElementById("products-grid");
    // storeId is already declared above

    function createProductCardHTML(product: any) {
      return `
      <div class="product-card group" data-id="${product.id}" data-product='${JSON.stringify(product).replace(/'/g, "&apos;")}'>
          <div class="product-image">
              <img src="${product.image}" alt="${product.name}" loading="lazy" />
              <div class="card-badges">
                  ${product.stock_quantity > 0 && product.stock_quantity <= (product.min_stock_level || 5) ? '<span class="badge warning-badge glass-effect warning">Selling Fast!</span>' : ""}
                  ${product.accepts_custom_note ? '<span class="badge icon-badge glass-effect" title="Customizable">✎</span>' : ""}
                  ${product.product_notice ? '<span class="badge icon-badge glass-effect" title="Has Notice">!</span>' : ""}
              </div>
              ${
                product.stock_quantity !== null && product.stock_quantity <= 0
                  ? `
              <div class="sold-out-ribbon-wrapper">
                  <span class="sold-out-ribbon">SOLD OUT</span>
              </div>
              <div class="out-of-stock-overlay"></div>`
                  : ""
              }
          </div>
          <div class="product-content">
              <h4 class="product-name">${product.name}</h4>
              <p class="product-short-desc">${product.description}</p>
              <div class="product-footer">
                  <span class="product-price">₹${Number(product.price).toFixed(2)}</span>
              </div>
              <div class="add-action-wrapper" onclick="event.stopPropagation()">
                  <button class="big-add-btn" ${product.stock_quantity <= 0 ? "disabled" : ""}>
                      ${product.stock_quantity <= 0 ? "SOLD OUT" : "ADD TO CART"}
                  </button>
                  <div class="stepper-controls" style="display: none;">
                      <button class="step-btn minus"><span class="material-symbols-rounded">remove</span></button>
                      <span class="qty-display">1</span>
                      <button class="step-btn plus"><span class="material-symbols-rounded">add</span></button>
                  </div>
              </div>
          </div>
      </div>
    `;
    }

    if (loadMoreBtn && productsGrid && storeId) {
      loadMoreBtn.addEventListener("click", async () => {
        const spinner = loadMoreBtn.querySelector(
          ".loader-spinner",
        ) as HTMLElement;
        loadMoreBtn.setAttribute("disabled", "true");
        if (spinner) spinner.style.display = "inline";

        try {
          const from = currentPage * PAGE_SIZE;
          const to = from + PAGE_SIZE - 1;

          const { data, error } = await (window as any).supabase
            .from("products")
            .select("*")
            .eq("store_id", storeId)
            .eq("is_in_stock", true)
            .order("created_at", { ascending: false })
            .range(from, to);

          if (error) throw error;

          if (data && data.length > 0) {
            data.forEach((p: any) => {
              const mappedProduct = {
                id: p.id,
                name: p.name,
                price: p.price,
                image:
                  p.images?.[0] || "https://placehold.co/600x400?text=No+Image",
                description: p.description,
                full_details: p.description,
                product_notice: p.product_notice,
                accepts_custom_note: p.accepts_custom_note,
                stock_quantity: p.stock_quantity,
                min_stock_level: p.min_stock_level,
              };

              // 1. Add to local state
              productsData.push(mappedProduct);

              // 2. Append to grid
              const tempDiv = document.createElement("div");
              tempDiv.innerHTML = createProductCardHTML(mappedProduct).trim();
              const newCard = tempDiv.firstChild as HTMLElement;
              productsGrid.appendChild(newCard);

              // 3. Attach logic
              attachToCard(newCard);
            });

            currentPage++;
            if (data.length < PAGE_SIZE) {
              loadMoreBtn.style.display = "none";
            }
          } else {
            loadMoreBtn.style.display = "none";
          }
        } catch (err) {
          console.error("Failed to load more products:", err);
        } finally {
          loadMoreBtn.removeAttribute("disabled");
          if (spinner) spinner.style.display = "none";
        }
      });
    }

    // ==========================================
    // 4. REAL-TIME UPDATES
    // ==========================================
    import { updateStock } from "../../lib/cartStore";

    if (storeId && (window as any).supabase) {
      console.log("Initializing Real-time for Store:", storeId);
      (window as any).supabase
        .channel(`store_products_${storeId}`)
        .on(
          "postgres_changes",
          {
            event: "UPDATE",
            schema: "public",
            table: "products",
            filter: `store_id=eq.${storeId}`,
          },
          (payload: any) => {
            const updated = payload.new;
            console.log(
              "Real-time Update received:",
              updated.name,
              "Stock:",
              updated.stock_quantity,
            );

            // 1. Update local productsData
            const pIdx = productsData.findIndex(
              (p: any) => p.id === updated.id,
            );
            if (pIdx > -1) {
              productsData[pIdx] = {
                ...productsData[pIdx],
                stock_quantity: updated.stock_quantity,
                is_in_stock: updated.is_in_stock,
                track_inventory: updated.track_inventory,
              };
            }

            // 2. Update Cart Store (caps quantity if stock dropped)
            updateStock(updated.id, updated.stock_quantity);

            // 3. Update UI DOM Elements
            const cards = document.querySelectorAll(
              `.product-card[data-id="${updated.id}"]`,
            );
            cards.forEach((cardEl: any) => {
              const isOutOfStock =
                updated.is_in_stock === false ||
                (updated.track_inventory &&
                  updated.stock_quantity !== null &&
                  updated.stock_quantity <= 0);
              const isLowStock =
                updated.stock_quantity !== null &&
                updated.stock_quantity > 0 &&
                updated.stock_quantity <= (updated.min_stock_level || 5);

              // Update ribbons and overlays
              let ribbon = cardEl.querySelector(".sold-out-ribbon-wrapper");
              let overlay = cardEl.querySelector(".out-of-stock-overlay");

              if (isOutOfStock) {
                if (!ribbon) {
                  cardEl.querySelector(".product-image").insertAdjacentHTML(
                    "beforeend",
                    `
                    <div class="sold-out-ribbon-wrapper">
                      <span class="sold-out-ribbon">SOLD OUT</span>
                    </div>
                  `,
                  );
                }
                if (!overlay) {
                  cardEl
                    .querySelector(".product-image")
                    .insertAdjacentHTML(
                      "beforeend",
                      '<div class="out-of-stock-overlay"></div>',
                    );
                }
              } else {
                ribbon?.remove();
                overlay?.remove();
              }

              // Update "Selling Fast" badge
              let warningBadge = cardEl.querySelector(".warning-badge");
              if (isLowStock && !isOutOfStock) {
                if (!warningBadge) {
                  cardEl
                    .querySelector(".card-badges")
                    .insertAdjacentHTML(
                      "afterbegin",
                      '<span class="badge warning-badge glass-effect warning">Selling Fast!</span>',
                    );
                }
              } else {
                warningBadge?.remove();
              }

              // Update Buttons
              const addBtn = cardEl.querySelector(".big-add-btn");
              if (addBtn) {
                addBtn.disabled = isOutOfStock;
                addBtn.textContent = isOutOfStock ? "SOLD OUT" : "ADD TO CART";
              }

              // Update internal data attribute for syncUI
              cardEl.dataset.product = JSON.stringify(
                productsData[pIdx],
              ).replace(/'/g, "&apos;");
            });

            // 4. Update Modal if open
            const modal = document.getElementById(
              "product-modal",
            ) as HTMLDialogElement;
            if (modal && modal.open) {
              const modalId = (window as any).currentModalProductId;
              if (modalId === updated.id) {
                const isOutOfStock =
                  updated.is_in_stock === false ||
                  (updated.track_inventory &&
                    updated.stock_quantity !== null &&
                    updated.stock_quantity <= 0);
                const alert = document.getElementById("modal-stock-alert");
                const addBtn = modal.querySelector(
                  ".big-add-btn",
                ) as HTMLButtonElement;

                if (alert)
                  alert.style.display =
                    updated.stock_quantity !== null &&
                    updated.stock_quantity <= (updated.min_stock_level || 5) &&
                    !isOutOfStock
                      ? "inline-block"
                      : "none";
                if (addBtn) {
                  addBtn.disabled = isOutOfStock;
                  addBtn.textContent = isOutOfStock
                    ? "SOLD OUT"
                    : "ADD TO CART";
                }
              }
            }
          },
        )
        .subscribe();
    }

    // ==========================================
    // 5. CART STATE SUBSCRIPTION
    // ==========================================
    cartItems.subscribe((items) => {
      // Sync Card Buttons
      document
        .querySelectorAll(".product-card:not([data-loading])")
        .forEach((card) => {
          const pid = (card as HTMLElement).dataset.id;
          if (pid) {
            const item = items.find((i: any) => i.id === pid);
            syncUI(pid, item ? item.quantity : 0);
          }
        });

      // Update Header Badge
      const totalCount = items.reduce((acc, i: any) => acc + i.quantity, 0);
      document
        .querySelectorAll(".cart-count")
        .forEach((el) => (el.textContent = totalCount.toString()));
      const cartCountNum = document.querySelector(".cart-count-num");
      if (cartCountNum) cartCountNum.textContent = totalCount.toString();

      // Render Drawer
      renderCart();

      // Update Checkout Summary if open
      const checkoutPage = document.getElementById("checkout-page");
      if (checkoutPage?.classList.contains("open")) {
        renderCheckoutSummary();
      }

      // Shadow state for PaymentProcessor (legacy compatibility)
      (window as any).cartState = items.reduce(
        (acc, i: any) => ({ ...acc, [i.id]: i.quantity }),
        {},
      );
      (window as any).cartNotes = items.reduce(
        (acc, i: any) => ({ ...acc, [i.id]: i.custom_note || "" }),
        {},
      );
    });
  </script>
</div>
